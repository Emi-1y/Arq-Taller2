<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <title>Pokeneas</title>

    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background-color: #f3f4f6;
        color: #222;
        font-family: 'Segoe UI', sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }

      .container {
        max-width: 900px;
        width: 100%;
        display: flex;
        align-items: center;
        gap: 2rem;
        background-color: #ffffff;
        border-radius: 18px;
        padding: 2rem;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
      }

      .image-section {
        flex: 1;
        text-align: center;
      }

      img {
        width: 320px;
        max-width: 100%;
        height: auto;
        object-fit: contain;
      }

      .info-section {
        flex: 1.2;
      }

      h1 {
        font-size: 2rem;
        color: #b91c1c;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 1rem;
      }

      .phrase {
        font-size: 1.1rem;
        font-style: italic;
        color: #444;
        line-height: 1.7;
        margin-bottom: 1.5rem;
        padding-left: 1rem;
        border-left: 4px solid #ef4444;
      }

      .api-btn {
        display: inline-block;
        padding: 0.6rem 1.2rem;
        background-color: #ef4444;
        color: #ffffff;
        text-decoration: none;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 1rem;
      }

      .api-btn:hover {
        background-color: #dc2626;
      }

      .container-id {
        color: #666;
        font-size: 0.85rem;
      }

      .container-id strong {
        color: #b91c1c;
      }

      @media (max-width: 700px) {
        .container {
          flex-direction: column;
          text-align: center;
        }

        .phrase {
          text-align: left;
        }
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="image-section">
        <img src="<%= pokenea.getImage() %>" alt="<%= pokenea.getName() %>">
      </div>

      <div class="info-section">
        <h1><%= pokenea.getName() %></h1>

        <p class="phrase">
          "<%= pokenea.getPhrase() %>"
        </p>

        <a href="/api/pokenea" class="api-btn">Ver JSON →</a>

        <p class="container-id">
          Container ID: <strong><%= containerId %></strong>
        </p>
      </div>
    </div>
  </body>
</html>
