<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <title>Pokeneas</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background-color: #181818;
        color: #f0f0f0;
        font-family: 'Segoe UI', sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }

      .container {
        max-width: 520px;
        width: 100%;
        text-align: center;
        background-color: #242424;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.45);
      }

      .top-half {
        background-color: #a80000;
        padding: 2rem 2rem 3rem;
      }

      h1 {
        font-size: 1.8rem;
        color: #ffffff;
        text-transform: uppercase;
        letter-spacing: 3px;
        font-weight: 700;
      }

      .pokeball-divider {
        position: relative;
        height: 28px;
        background: linear-gradient(to bottom, #a80000 50%, #242424 50%);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .pokeball-divider::before {
        content: '';
        position: absolute;
        width: 100%;
        height: 5px;
        background-color: #181818;
        top: 50%;
        transform: translateY(-50%);
      }

      .pokeball-btn {
        width: 36px;
        height: 36px;
        background-color: #ffffff;
        border-radius: 50%;
        border: 5px solid #181818;
        z-index: 1;
        box-shadow: 0 0 0 3px #ffffff;
      }

      .bottom-half {
        padding: 1.5rem 2rem 2rem;
      }

      img {
        width: 320px;
        max-width: 100%;
        height: 260px;
        object-fit: contain;
        background-color: #eeeeee;
        border-radius: 16px;
        border: 5px solid #181818;
        margin-top: -55px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.45);
      }

      .phrase {
        font-size: 1rem;
        font-style: italic;
        color: #dddddd;
        line-height: 1.7;
        margin: 1.5rem 0;
        padding: 1rem;
        border-left: 3px solid #a80000;
        text-align: left;
      }

      .container-id {
        color: #999;
        font-size: 0.8rem;
        padding-top: 1rem;
        border-top: 1px solid #3a3a3a;
      }

      .container-id strong {
        color: #d94a4a;
      }

      .api-btn {
        display: inline-block;
        margin-bottom: 0.8rem;
        padding: 0.5rem 1.2rem;
        background-color: #a80000;
        color: #ffffff;
        text-decoration: none;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 1px;
      }

      .api-btn:hover {
        background-color: #c62828;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="top-half">
        <h1><%= pokenea.getName() %></h1>
      </div>

      <div class="pokeball-divider">
        <div class="pokeball-btn"></div>
      </div>

      <div class="bottom-half">
        <img src="<%= pokenea.getImage() %>" alt="<%= pokenea.getName() %>">

        <p class="phrase">"<%= pokenea.getPhrase() %>"</p>

        <div class="container-id">
          <a href="/api/pokenea" class="api-btn">Ver JSON →</a>
          <br>
          Container ID: <strong><%= containerId %></strong>
        </div>
      </div>
    </div>
  </body>
</html>
